{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug (OpenOCD / ST-LINK)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/Debug/STM32L496_Boot.elf",
            "args": [],
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "arm-none-eabi-gdb",
            "miDebuggerServerAddress": "localhost:3333",
            "debugServerPath": "openocd",
            "debugServerArgs": "-f interface/stlink.cfg -f target/stm32l4x.cfg",
            "serverStarted": "Listening on port 3333",
            "filterStderr": true,
            "launchCompleteCommand": "exec-run",
            "setupCommands": [
                { "text": "set remotetimeout 30" },
                { "text": "monitor reset halt" }
            ],
            "postRemoteConnectCommands": [
                { "text": "monitor reset halt" },
                { "text": "load" }
            ]
        }
    ]
}
