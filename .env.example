# .env.example — copy to .env and fill in your values
# .env is gitignored and must NEVER be committed.
#
# -----------------------------------------------------------------------
# LOCAL DEVELOPMENT
# -----------------------------------------------------------------------
# Store the private key OUTSIDE the repository so it can never be
# accidentally committed, even if .gitignore is misconfigured.
#
# Recommended location on Windows:
#   %USERPROFILE%\.stm32-keys\STM32L496_private_key.pem
#
# To move the key there now:
#   New-Item -ItemType Directory -Force "$HOME\.stm32-keys"
#   Move-Item tools\private_key.pem "$HOME\.stm32-keys\STM32L496_private_key.pem"
#
SIGNING_KEY_PATH=C:\Users\YourName\.stm32-keys\STM32L496_private_key.pem
SIGNING_PASSPHRASE=<your-passphrase>

# -----------------------------------------------------------------------
# CI / CD PIPELINE  (GitHub Actions, Azure DevOps, GitLab CI, etc.)
# -----------------------------------------------------------------------
# Do NOT use .env in CI.  Instead, configure these as masked/protected
# secrets in your CI platform's secret store:
#
#   SIGNING_PASSPHRASE   — the PEM passphrase
#   SIGNING_PRIVATE_KEY  — the full PEM file contents (copy-paste the
#                          entire private_key.pem including header/footer)
#
# build.ps1 automatically detects SIGNING_PRIVATE_KEY, writes it to a
# secure temp file, passes --key to sign_image.py, and deletes the temp
# file immediately after signing (even on failure).
#
# GitHub Actions example:
#
#   - name: Build and sign firmware
#     env:
#       SIGNING_PASSPHRASE: ${{ secrets.SIGNING_PASSPHRASE }}
#       SIGNING_PRIVATE_KEY: ${{ secrets.SIGNING_PRIVATE_KEY }}
#     run: |
#       pwsh -File build.ps1 -Config Release -Sign
